{
  "name": "@ito-frontend/eslint-config",
  "type": "module",
  "version": "2.0.0-beta.1",
  "packageManager": "pnpm@8.15.8+sha512.d1a029e1a447ad90bc96cd58b0fad486d2993d531856396f7babf2d83eb1823bb83c5a3d0fc18f675b2d10321d49eb161fece36fe8134aa5823ecd215feed392",
  "description": "ESLint Config for OneAD ITO Team. Powered by @antfu/eslint-config",
  "publishConfig": {
    "@ito-frontend": "registry=https://npm.pkg.github.com"
  },
  "author": "ito-frontend",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/ito-frontend/eslint-config.git"
  },
  "keywords": [],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint . --fix",
    "clear": "rm -rf dist/",
    "build": "npm run clear && rollup -c",
    "dev": "rollup -c -w",
    "lint:rules": "npx @eslint/config-inspector",
    "release": "bumpp"
  },
  "peerDependencies": {
    "eslint": ">=8.57.0"
  },
  "dependencies": {
    "@antfu/eslint-config": "^2.22.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-tailwindcss": "^3.17.4"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^26.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "bumpp": "^9.4.1",
    "eslint": "^9.6.0",
    "lint-staged": "^15.2.7",
    "rollup": "^4.18.1",
    "rollup-plugin-dts": "^6.1.1",
    "simple-git-hooks": "^2.11.1",
    "typescript": "^5.5.3"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
